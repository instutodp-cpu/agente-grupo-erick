# Copie este arquivo para .env e preencha as variáveis

# Chave da API da Anthropic (Claude)
ANTHROPIC_API_KEY=sua_chave_aqui

# Connection string do Supabase (Session Pooler)
# Formato: postgresql://postgres.PROJECT_ID:SENHA@aws-1-sa-east-1.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres.yxmdrrwqxwzsdgcgskrm:SUA_SENHA@aws-1-sa-east-1.pooler.supabase.com:5432/postgres

# Porta (Railway define automaticamente)
PORT=3001

# Guardrails de SQL livre (fallback Claude) — opcionais
# LIMIT padrão aplicado quando a consulta não traz LIMIT
SQL_GUARDRAIL_DEFAULT_LIMIT=1000
# Timeout (ms) específico para execução do SQL livre gerado pela IA
SQL_GUARDRAIL_QUERY_TIMEOUT_MS=15000

# Timeout (ms) por consulta no script de validação dos SQL Templates — opcional
SQL_TEMPLATE_VALIDATION_TIMEOUT_MS=30000

# Segredo dos endpoints administrativos (/admin/*). Sem ele, /admin/* fica
# desabilitado (503). Envie no header: x-admin-secret: <valor>
ADMIN_SECRET=defina-um-segredo-longo-e-aleatorio
