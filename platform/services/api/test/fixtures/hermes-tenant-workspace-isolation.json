{
  "workspace_types": ["personal", "grupo_erick", "external_client"],
  "tenant_id_formats": ["personal::<user_id>", "grupo_erick", "client::<client_id>"],
  "workspace_identity_fields": [
    "workspace_type",
    "tenant_id",
    "user_id",
    "role",
    "company_id",
    "store_id",
    "client_id",
    "allowed_domains",
    "denied_domains",
    "scope_source",
    "scope_version",
    "isolation_policy",
    "confirmation_policy",
    "governance_policy"
  ],
  "isolation_boundaries": [
    "personal_boundary",
    "grupo_erick_boundary",
    "external_client_boundary",
    "store_boundary",
    "company_boundary",
    "user_boundary",
    "role_boundary",
    "provider_boundary",
    "memory_boundary",
    "audit_boundary"
  ],
  "workspace_default_policies": {
    "personal": {
      "tenant_id_pattern": "personal::<user_id>",
      "allowed_domains": [
        "pessoal",
        "agenda",
        "produtividade",
        "viagens",
        "saude",
        "desenvolvimento_pessoal"
      ],
      "denied_domains": [
        "financeiro_corporativo",
        "compras_corporativas",
        "rh_corporativo",
        "external_client_data"
      ],
      "business_data_access": false
    },
    "grupo_erick": {
      "tenant_id_pattern": "grupo_erick",
      "allowed_domains": [
        "financeiro",
        "compras",
        "marketing",
        "treinamento",
        "rh",
        "operacoes",
        "atendimento",
        "desenvolvimento"
      ],
      "denied_domains": ["personal_private_data", "external_client_private_data"],
      "business_data_access": "read_only_candidate"
    },
    "external_client": {
      "tenant_id_pattern": "client::<client_id>",
      "allowed_domains": [
        "configurable_by_client",
        "atendimento",
        "relatorios",
        "automacao_assistida",
        "treinamento_if_contracted",
        "marketing_if_contracted"
      ],
      "denied_domains": [
        "grupo_erick_internal_data",
        "personal_private_data",
        "other_client_private_data"
      ],
      "business_data_access": "own_client_only"
    }
  },
  "memory_scope_rules": {
    "required_fields": [
      "workspace_type",
      "tenant_id",
      "user_id",
      "memory_scope",
      "source_domain",
      "sensitivity_level",
      "retention_policy",
      "sanitized"
    ],
    "sanitized_required": true,
    "cross_workspace_memory_allowed": false
  },
  "audit_scope_rules": {
    "required_fields": [
      "trace_id",
      "event_id",
      "workspace_type",
      "tenant_id",
      "user_id",
      "domain",
      "event_type",
      "status",
      "simulated",
      "executed",
      "timestamp"
    ],
    "cross_tenant_audit_allowed": false
  },
  "provider_scope_rules": {
    "provider_requires_workspace_type": true,
    "provider_requires_tenant_id": true,
    "mcp_requires_workspace_type": true,
    "mcp_requires_tenant_id": true,
    "provider_can_infer_tenant_from_text": false,
    "mcp_action_tool_allowed": false
  },
  "grupo_erick_data_rules": {
    "tenant_id": "grupo_erick",
    "store_id_required_when_applicable": true,
    "company_id_required_when_applicable": true,
    "financeiro_sensitive": true,
    "compras_sensitive": true,
    "future_access_mode": "read_only_candidate",
    "write_allowed": false
  },
  "external_client_rules": {
    "tenant_id_pattern": "client::<client_id>",
    "client_id_required": true,
    "cross_client_access_allowed": false,
    "grupo_erick_access_allowed": false,
    "shared_templates_must_be_sanitized": true,
    "cross_tenant_metrics_require_anonymization": true
  },
  "default_rules": {
    "tenant_id_required": true,
    "workspace_type_required": true,
    "user_id_required": true,
    "cross_workspace_access_allowed": false,
    "cross_tenant_access_allowed": false,
    "cross_user_access_allowed": false,
    "prompt_can_change_tenant": false,
    "provider_can_change_tenant": false,
    "memory_requires_tenant": true,
    "audit_requires_tenant": true,
    "provider_requires_tenant": true,
    "mcp_requires_tenant": true,
    "cache_global_sensitive_data_allowed": false,
    "rag_requires_tenant_namespace": true,
    "second_brain_requires_tenant": true,
    "simulated": true,
    "executed": false,
    "write_allowed": false,
    "action_allowed": false,
    "mock_first": true
  },
  "blocking_rules": [
    "missing_tenant_id",
    "missing_workspace_type",
    "missing_user_id",
    "personal_to_grupo_erick_leakage",
    "grupo_erick_to_personal_leakage",
    "grupo_erick_to_external_client_leakage",
    "external_client_to_grupo_erick_leakage",
    "external_client_to_external_client_leakage",
    "prompt_tenant_override_attempt",
    "provider_tenant_override_attempt",
    "memory_without_tenant",
    "audit_without_tenant",
    "cache_global_sensitive_data",
    "provider_output_without_workspace",
    "mcp_call_without_tenant",
    "supabase_without_tenant_policy",
    "vector_db_without_tenant_namespace",
    "second_brain_without_tenant_isolation",
    "raw_message_stored",
    "secret_stored",
    "executed_true",
    "write_allowed_true",
    "action_allowed_true"
  ],
  "forbidden_fields": [
    "token",
    "secret",
    "env",
    "headers",
    "cookies",
    "credentials",
    "payload",
    "rawPayload",
    "rawMessage",
    "userMessage",
    "requiredAdapters",
    "authorization",
    "password",
    "stackTrace",
    "apiKey",
    "accessToken",
    "refreshToken",
    "requestBody",
    "responseBody",
    "rawTranscript",
    "rawAudio",
    "rawHtml",
    "privateUrl",
    "webhookSecret"
  ],
  "required_contract_references": [
    "MEMORY_POLICY.md",
    "USER_PEER_MEMORY_SCOPES.md",
    "SECOND_BRAIN_INBOX_CONTRACT.md",
    "PERMISSION_MATRIX.md",
    "GOVERNANCE_CHECK_REPORT.md",
    "INTEGRATION_SECURITY_BOUNDARY.md",
    "EXTERNAL_INTEGRATION_PROVIDER_REGISTRY.md",
    "EXTERNAL_PROVIDER_PERMISSION_OVERLAY.md",
    "EXTERNAL_PROVIDER_MOCK_ADAPTER_HARNESS.md",
    "EXTERNAL_PROVIDER_AUDIT_COST_RATE_LIMIT.md",
    "GOLDEN_SCENARIOS.md",
    "DOMAIN_ONBOARDING.md",
    "SKILL_CANDIDATE_REGISTRY.md",
    "OPERATOR_RUNBOOK.md"
  ],
