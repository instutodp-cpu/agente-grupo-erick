# Hermes AI Platform v2 — variáveis de ambiente (exemplo).
# Copie para .env e ajuste. O docker-compose funciona sem .env (usa defaults),
# mas em produção (Railway) defina valores reais e segredos fortes.

# ── Núcleo ────────────────────────────────────────────────────────────────────
HERMES_VERSION=2.0.0-scaffold
API_PORT=8080
WORKER_HEARTBEAT_MS=15000

# ── Postgres / Supabase (fonte transacional) ─────────────────────────────────
POSTGRES_USER=hermes
POSTGRES_PASSWORD=hermes
POSTGRES_DB=hermes
POSTGRES_PORT=5432
# Em produção, use a connection string do Supabase:
# DATABASE_URL=postgres://usuario:senha@host:5432/db

# ── Redis (fila / cache / sessões) ───────────────────────────────────────────
REDIS_PORT=6379
# REDIS_URL=redis://redis:6379

# ── Qdrant (RAG / memória vetorial) ──────────────────────────────────────────
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
# QDRANT_URL=http://qdrant:6333

# ── MCP Gateway (acesso a MCPs sempre via policy layer) ──────────────────────
MCP_GATEWAY_URL=http://mcp-gateway:8081

# ── Modelos / provedores (NÃO commitar valores reais) ────────────────────────
# ANTHROPIC_API_KEY=defina-no-.env-ou-no-Railway
# ADMIN_SECRET=defina-um-segredo-longo-e-aleatorio
